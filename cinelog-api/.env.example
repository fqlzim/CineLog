# ============================================================
# VARIÁVEIS DE AMBIENTE — API CineLog
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o .env com senhas reais no Git!
# ============================================================

# Porta onde a API Express vai escutar requisições.
PORT=3000

# Credenciais do MySQL (mesmas do MySQL Workbench).
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=12345678
DB_NAME=cinelog

# Segredo para assinar tokens JWT (use uma string longa e aleatória).
JWT_SECRET=cinelog_jwt_secret_trocar_em_producao_2026

# Tempo de validade do token (ex: 7d = 7 dias).
JWT_EXPIRES_IN=7d

# Chave da API TMDB — https://www.themoviedb.org/settings/api
# Aceita:
#   • API Key (v3) — string curta
#   • Read Access Token (v4) — JWT que começa com eyJ (recomendado)
TMDB_API_KEY=sua_chave_ou_token_tmdb_aqui
